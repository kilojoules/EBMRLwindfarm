\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Penalty weight $\lambda (\rho , \tau )$ across the budget--time state space for three risk-aversion values $\eta $. The TWAP diagonal (white dashed, $u = \rho /\tau = 1$) separates surplus (blue, $\lambda < 1$) from deficit (red, $\lambda > 1$). Contour lines show penalty magnitudes. Higher $\eta $ produces steeper gradients near the diagonal, concentrating budget spending into favorable conditions.}}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:contours}{{3}{8}{Penalty weight $\lambda (\rho , \tau )$ across the budget--time state space for three risk-aversion values $\eta $. The TWAP diagonal (white dashed, $u = \rho /\tau = 1$) separates surplus (blue, $\lambda < 1$) from deficit (red, $\lambda > 1$). Contour lines show penalty magnitudes. Higher $\eta $ produces steeper gradients near the diagonal, concentrating budget spending into favorable conditions}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Yaw angle heatmaps (turbine $\times $ timestep) showing the spatial-temporal pattern. Unconstrained (left): persistent positive/negative yaw steering across all turbines. AC $\eta =2$ (middle): nearly zero yaw---very conservative. AC $\eta =5$ (right): mostly zero with a concentrated burst of negative yaw (blue) near the end, representing strategic budget spending.}}{8}{figure.caption.6}\protected@file@percent }
\newlabel{fig:wf_heatmap}{{4}{8}{Yaw angle heatmaps (turbine $\times $ timestep) showing the spatial-temporal pattern. Unconstrained (left): persistent positive/negative yaw steering across all turbines. AC $\eta =2$ (middle): nearly zero yaw---very conservative. AC $\eta =5$ (right): mostly zero with a concentrated burst of negative yaw (blue) near the end, representing strategic budget spending}{figure.caption.6}{}}
